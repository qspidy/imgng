{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "imgul",
  "main": "src/index.js",
  "compatibility_date": "2026-04-21",
  "secrets": {
    "required": ["BASIC_PASS"]
  },
  "workers_dev": true,
  "r2_buckets": [
    {
      "binding": "IMAGES",
      "bucket_name": "images"
    }
  ],
  "vars": {
    "API_PATH_PREFIX": "upload",
    "BASIC_USER": "user",
    "PUBLIC_BASE_URL": "",
    "PUBLIC_PATH_PREFIX": ""
  }
}
